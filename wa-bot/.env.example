# ============================================================
# .env.example — WhatsApp Bot GMR 8
# Salin ke .env dan isi sesuai konfigurasi Anda
# ============================================================

# URL website GMR8 (tanpa trailing slash)
# Kalau hosting: https://namadomainanda.com/GMR8
SITE_URL=http://localhost:8000

# API Key — HARUS SAMA dengan yang ada di api/wa-webhook.php
WA_API_KEY=GANTI-DENGAN-KEY-RAHASIA-PANJANG-ANDA

# ID Grup WhatsApp RT (salin dari log bot saat pertama jalan)
# Format: 628xxxxxxxxxx-xxxxxxxxx@g.us
GROUP_ID=KOSONGKAN_DULU_ISI_SETELAH_BOT_JALAN

# Nomor telepon bot (nomor yang scan QR)
# Tanpa +, tanpa tanda baca — format: 628xxxxxxxxxx
BOT_NUMBER=628xxxxxxxxxx

# Nama bot yang tampil di pesan
BOT_NAME=Bot GMR 8

# Bahasa log (silent = minimal, info = verbose)
LOG_LEVEL=silent
